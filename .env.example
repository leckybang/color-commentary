# ============================================================
# CLIENT-SIDE (safe to expose, prefixed with VITE_)
# ============================================================

# Supabase (already set up)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# TMDB v3 API key (free, client-safe)
# Get one at https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=

# Google Books API key (free, client-safe) - recommended to avoid rate limits
# Get one at https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_BOOKS_API_KEY=

# NYT Books API key (free, client-safe) - powers Weekly Radar bestseller picks
# Get one at https://developer.nytimes.com/ — enable the "Books API"
VITE_NYT_BOOKS_API_KEY=

# ============================================================
# SERVER-SIDE (Netlify Functions only — never exposed to client)
# ============================================================

# Spotify Client Credentials
# Get these at https://developer.spotify.com/dashboard (create an app)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Anthropic API key for Claude-powered note parsing
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Your production site URL (for CORS)
# e.g. https://color-commentary.netlify.app
ALLOWED_ORIGIN=http://localhost:5173
